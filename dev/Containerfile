# Pinned to 1.26.4 (over `latest`) for a reproducible image whose stdlib has
# current advisories patched. Bump as new advisories land.
FROM docker.io/library/golang:1.26.4@sha256:792443b89f65105abba56b9bd5e97f680a80074ac62fc844a584212f8c8102c3

# Recent golang base images default GOTOOLCHAIN=local, which blocks auto-download
# of a higher toolchain directive in go.mod. `auto` lets go.mod pin a newer
# toolchain than this base image without a Containerfile change.
ENV GOTOOLCHAIN=auto

RUN apt-get update && apt-get install -y git curl jq reuse yamllint shellcheck

# markdownlint-cli2 mirrors the DavidAnson/markdownlint-cli2-action used in
# verify.yml, so `markdownlint-cli2 '**/*.md'` reproduces the CI markdown gate
# locally against .markdownlint.yaml. Node comes from the upstream tarball
# rather than Debian's `npm` package, which drags in ~600 MB of eslint/webpack/
# X11 transitive deps the dev shell has no use for.
# renovate: datasource=node-version depName=node
ARG NODE_VERSION=24.18.0
RUN ARCH="$(dpkg --print-architecture)" \
    && case "$ARCH" in amd64) N=x64 ;; arm64) N=arm64 ;; armhf) N=armv7l ;; *) N="$ARCH" ;; esac \
    && curl -fsSL "https://nodejs.org/dist/v${NODE_VERSION}/node-v${NODE_VERSION}-linux-${N}.tar.gz" \
       | tar -xz -C /usr/local --strip-components=1 \
    && npm install -g markdownlint-cli2

# typos: the spell-checker the CI `typos` job runs against .typos.toml. It is a
# Rust binary with no Go/Node/Python toolchain in this image, so fetch the
# prebuilt release tarball rather than `cargo install`. Keep this in step with
# the version the crate-ci/typos action ships so a local run catches exactly
# what CI does — Renovate bumps it from the upstream releases.
# renovate: datasource=github-releases depName=crate-ci/typos
ARG TYPOS_VERSION=1.47.2
RUN ARCH="$(uname -m)" \
    && case "$ARCH" in x86_64) T=x86_64 ;; aarch64) T=aarch64 ;; *) T="$ARCH" ;; esac \
    && curl -fsSL "https://github.com/crate-ci/typos/releases/download/v${TYPOS_VERSION}/typos-v${TYPOS_VERSION}-${T}-unknown-linux-musl.tar.gz" \
       | tar -xz -C /usr/local/bin ./typos

# Standalone static-analysis tools — the CI verify gate runs these directly.
# golangci-lint is intentionally NOT installed (banned project-wide).
# gofumpt: strict formatting; gosec: security scanner; arch-go: architecture
# rules (arch-go.yml); actionlint: GitHub Actions workflow linter; govulncheck:
# known-vulnerability scanner (the CI vulnerabilities job).
RUN go install honnef.co/go/tools/cmd/staticcheck@latest
RUN go install mvdan.cc/gofumpt@latest
RUN go install github.com/securego/gosec/v2/cmd/gosec@latest
RUN go install github.com/arch-go/arch-go@latest
RUN go install github.com/rhysd/actionlint/cmd/actionlint@latest
RUN go install golang.org/x/vuln/cmd/govulncheck@latest

# envtest assets for the controller tests. controller-gen is NOT installed here:
# it's a go.mod `tool` directive, run via `go tool controller-gen` (one pinned
# version in go.mod, bumped by Renovate's gomod manager).
RUN go install sigs.k8s.io/controller-runtime/tools/setup-envtest@latest

# Pre-stage an envtest asset bundle (kube-apiserver + etcd) so envtest-based
# controller tests run without network access. The `assets` symlink keeps the
# path stable across image rebuilds; KUBEBUILDER_ASSETS points the
# controller-runtime envtest package at it. The version floats to the newest
# bundle envtest publishes at build time — no pin to bump (CI's verify.yml tests
# the newest several minors via the same `setup-envtest list` discovery).
RUN k8s="$(setup-envtest list 2>/dev/null | grep -oE '[0-9]+\.[0-9]+\.[0-9]+' | sort -V | tail -1)" \
    && setup-envtest use "${k8s}" --bin-dir /usr/local/kubebuilder/bin \
    && ln -s "$(setup-envtest use "${k8s}" --bin-dir /usr/local/kubebuilder/bin -p path)" /usr/local/kubebuilder/assets
ENV KUBEBUILDER_ASSETS=/usr/local/kubebuilder/assets

# htmltest + biome are the website linters — the rendered-HTML and CSS counterpart
# to markdownlint above. htmltest checks the built site under docs/public/ (dead
# internal links, missing alt text, broken anchors); biome lints the theme's CSS
# (docs/themes/metio/assets/css). Both ship as single static binaries. Kept last
# so a version bump here doesn't invalidate the expensive go-install layers.
# renovate: datasource=github-releases depName=wjdp/htmltest
ARG HTMLTEST_VERSION=0.17.0
# renovate: datasource=github-releases depName=biomejs/biome extractVersion=^@biomejs/biome@(?<version>.+)$
ARG BIOME_VERSION=2.5.1
RUN ARCH="$(dpkg --print-architecture)" \
    && case "$ARCH" in amd64) HT=amd64; BIO=x64 ;; arm64) HT=arm64; BIO=arm64 ;; *) HT="$ARCH"; BIO="$ARCH" ;; esac \
    && curl -fsSL "https://github.com/wjdp/htmltest/releases/download/v${HTMLTEST_VERSION}/htmltest_${HTMLTEST_VERSION}_linux_${HT}.tar.gz" \
       | tar -xz -C /usr/local/bin htmltest \
    && curl -fsSL -o /usr/local/bin/biome "https://github.com/biomejs/biome/releases/download/@biomejs/biome@${BIOME_VERSION}/biome-linux-${BIO}" \
    && chmod +x /usr/local/bin/biome

# helm-schema (dadav/helm-schema): generates each chart's values.schema.json
# from its values.yaml `# @schema` annotations. hack/gen-docs-data.sh runs it on
# the chart sources fetched from helm-charts to build the docs values reference.
# dadav/helm-schema release tags carry no `v` prefix (e.g. 0.23.4).
# renovate: datasource=github-releases depName=dadav/helm-schema
ARG GO_HELM_SCHEMA_VERSION=0.23.4
RUN ARCH="$(uname -m)" \
    && case "$ARCH" in x86_64) S=x86_64 ;; aarch64) S=arm64 ;; *) S="$ARCH" ;; esac \
    && curl -fsSL "https://github.com/dadav/helm-schema/releases/download/${GO_HELM_SCHEMA_VERSION}/helm-schema_${GO_HELM_SCHEMA_VERSION}_Linux_${S}.tar.gz" \
       | tar -xz -C /usr/local/bin helm-schema
